# ── Auto-provisioned by Railway plugins ───────────────────────────────────────
# Add a Postgres plugin and a Redis plugin in your Railway project.
# Railway sets these automatically — do not set them manually.
DATABASE_URL=         # set by Railway Postgres plugin
REDIS_URL=            # set by Railway Redis plugin

# ── Required API keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Catalog seeding ───────────────────────────────────────────────────────────
# Comma-separated Spotify playlist IDs to seed the song catalog on first deploy.
# Example: 37i9dQZF1DXcBWIGoYBM5M,37i9dQZF1DX4dyzvuaRJ0n
SEED_PLAYLISTS=

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_VIBE_PER_MINUTE=10
RATE_LIMIT_WS_PER_HOUR=20
RATE_LIMIT_SESSIONS_PER_HOUR=5

# ── Session config ────────────────────────────────────────────────────────────
MAX_SESSION_MEMBERS=10

# ── Runtime ───────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
